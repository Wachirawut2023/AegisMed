# ─────────────────────────────────────────────────────────────
# AegisMed configuration
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Your Fireworks AI API key.
# Get it from https://fireworks.ai after signing up through the
# AMD AI Developer Program (you receive $50 in free credits).
FIREWORKS_API_KEY=

# Which model to use on Fireworks AI.
# We default to Google's Gemma (for the "Best AMD-Hosted Gemma Project" prize).
# You can swap this on hackathon launch day once the model list is confirmed.
MODEL=accounts/fireworks/models/gemma-3-27b-it

# Demo mode:
#   auto  = use the real AI if an API key is set, otherwise show sample output
#   true  = always show sample output (no API key needed, costs nothing)
#   false = always use the real AI (errors if no API key)
DEMO_MODE=auto

# Specialist selection (controls cost per case):
#   relevant = convene only the specialists relevant to each case (default,
#              fewer model calls). Always keeps Medical Genetics; falls back to
#              the full board if routing is unsure.
#   all      = always convene all 7 specialists (e.g. for the demo video).
SPECIALIST_SELECTION=relevant

# CORS: comma-separated list of origins allowed to call this API.
# Only needed when the frontend is hosted separately from this backend
# (e.g. frontend on Firebase Hosting, this backend on Cloud Run).
# Example: ALLOWED_ORIGINS=https://your-project.web.app,https://your-project.firebaseapp.com
# Default "*" allows any origin — fine for same-origin/local/Docker use.
ALLOWED_ORIGINS=*

# ── Self-hosted primary + serverless fallback (optional) ──────────────────
# Point LLM_API_URL at a self-hosted OpenAI-compatible endpoint instead of
# Fireworks — e.g. vLLM serving Gemma on an AMD Developer Cloud GPU droplet.
# FIREWORKS_API_KEY above is sent as this endpoint's bearer token (leave it
# blank if the self-hosted server has no --api-key set).
# Leave LLM_API_URL unset to keep using Fireworks (the default).
LLM_API_URL=

# If the primary call fails, retry once against this fallback model/endpoint
# before giving up — e.g. a serverless Fireworks model (no cold start, no
# dedicated-deployment cost) as a safety net behind a self-hosted primary
# that might be down or still warming up. Leave FALLBACK_MODEL empty to
# disable the fallback entirely (the primary's error is raised as-is).
FALLBACK_MODEL=
FALLBACK_API_URL=https://api.fireworks.ai/inference/v1/chat/completions
FALLBACK_API_KEY=
