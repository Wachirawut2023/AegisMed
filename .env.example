# ─────────────────────────────────────────────────────────────
# AegisMed configuration
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Your Fireworks AI API key.
# Get it from https://fireworks.ai after signing up through the
# AMD AI Developer Program (you receive $50 in free credits).
FIREWORKS_API_KEY=

# Which model to use on Fireworks AI. Used by every agent (intake,
# retrieval, all specialists) EXCEPT the synthesis agent — see
# SYNTHESIS_MODEL below.
# We default to Google's Gemma (for the "Best AMD-Hosted Gemma Project" prize).
# You can swap this on hackathon launch day once the model list is confirmed.
# NOTE: on some accounts gemma-3-27b-it isn't available on Fireworks'
# serverless tier (a 404 "Model not found, inaccessible, and/or not deployed"
# means this) — either stand up a dedicated deployment (see finetune/deploy.py)
# or point MODEL at a model your account can actually call serverless.
MODEL=accounts/fireworks/models/gemma-3-27b-it

# Which model the synthesis ("board chair") agent uses. Optional — falls
# back to MODEL when unset. After fine-tuning (see finetune/ and
# docs/FINETUNE.md), point THIS (not MODEL) at your tuned model, e.g.
# SYNTHESIS_MODEL=accounts/<your-account>/models/aegismed-gemma-tuned
# The fine-tuning data only trains the synthesis agent's task, so pointing
# MODEL itself at the tuned adapter would also (mis)route intake/retrieval/
# specialists through it.
# SYNTHESIS_MODEL=

# ── Fine-tuning only (not needed to run the app) ──
# Your Fireworks account id — find it in the dashboard URL:
#   app.fireworks.ai/dashboard/<ACCOUNT_ID>/...
# Used by finetune/run_finetune.py to create the fine-tuning job.
FIREWORKS_ACCOUNT_ID=
# Optional: the base model to fine-tune from (defaults to MODEL above).
# BASE_MODEL=accounts/fireworks/models/gemma-3-27b-it

# Demo mode:
#   auto  = use the real AI if an API key is set, otherwise show sample output
#   true  = always show sample output (no API key needed, costs nothing)
#   false = always use the real AI (errors if no API key)
DEMO_MODE=auto

# Specialist selection (controls cost per case):
#   relevant = convene only the specialists relevant to each case (default,
#              fewer model calls). Always keeps Medical Genetics; falls back to
#              the full board if routing is unsure.
#   all      = always convene all 7 specialists (e.g. for the demo video).
SPECIALIST_SELECTION=relevant
