# ─────────────────────────────────────────────────────────────
# AegisMed configuration
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Your Fireworks AI API key.
# Get it from https://fireworks.ai after signing up through the
# AMD AI Developer Program (you receive $50 in free credits).
FIREWORKS_API_KEY=

# Which model to use on Fireworks AI.
# We default to Google's Gemma (for the "Best AMD-Hosted Gemma Project" prize).
# You can swap this on hackathon launch day once the model list is confirmed.
MODEL=accounts/fireworks/models/gemma-3-27b-it

# Demo mode:
#   auto  = use the real AI if an API key is set, otherwise show sample output
#   true  = always show sample output (no API key needed, costs nothing)
#   false = always use the real AI (errors if no API key)
DEMO_MODE=auto
