# ─────────────────────────────────────────────────────────────
# AegisMed configuration
# Copy this file to `.env` and fill in your own values:
#     cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Your Fireworks AI API key.
# Get it from https://fireworks.ai after signing up through the
# AMD AI Developer Program (you receive $50 in free credits).
FIREWORKS_API_KEY=

# Which model to use on Fireworks AI.
# We default to Google's Gemma (for the "Best AMD-Hosted Gemma Project" prize).
# You can swap this on hackathon launch day once the model list is confirmed.
MODEL=accounts/fireworks/models/gemma-3-27b-it

# Demo mode:
#   auto  = use the real AI if an API key is set, otherwise show sample output
#   true  = always show sample output (no API key needed, costs nothing)
#   false = always use the real AI (errors if no API key)
DEMO_MODE=auto

# Specialist selection (controls cost per case):
#   relevant = convene only the specialists relevant to each case (default,
#              fewer model calls). Always keeps Medical Genetics; falls back to
#              the full board if routing is unsure.
#   all      = always convene all 7 specialists (e.g. for the demo video).
SPECIALIST_SELECTION=relevant

# ─────────────────────────────────────────────────────────────
# AMD Developer Cloud: self-hosted Gemma (optional)
# ─────────────────────────────────────────────────────────────
# By default AegisMed calls Fireworks AI, which serves Gemma on AMD Instinct
# MI300X GPUs — so inference already runs on AMD hardware with no extra setup.
#
# To instead run Gemma yourself on an AMD Developer Cloud GPU instance (vLLM or
# Ollama, both OpenAI-compatible), point AegisMed at it here. Leave empty to use
# the default Fireworks endpoint. See docs/DEPLOY_AMD.md for the full walkthrough.
#     LLM_BASE_URL=http://<your-amd-instance>:8000/v1
LLM_BASE_URL=

# ─────────────────────────────────────────────────────────────
# Performance (sub-30s response guarantee)
# ─────────────────────────────────────────────────────────────
# Read timeout (seconds) for a single model call. Kept tight so no one upstream
# call can dominate the request budget.
LLM_READ_TIMEOUT_SECONDS=12

# Overall wall-clock budget (seconds) for one /api/diagnose request. The board
# aborts cleanly with an HTTP 504 rather than silently exceeding this.
REQUEST_TIMEOUT_SECONDS=28
